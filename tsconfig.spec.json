{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "types": [
      "jest"
    ]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "src/**/*.d.ts",
    "setup-jest.ts"
  ]
}